  m_Name: Narrative_CraftingPrompt
  m_EditorClassIdentifier: Assembly-CSharp::_Scripts.Tutorial.TutorialNarrativeAsset
  beats:
  - speaker: 2
    text: Pick up crafting schematics to be a great craft-man.
    autoAdvanceDelay: 6
