  m_Script: {fileID: 11500000, guid: fc31e614b1789304f9899d89689c7c54, type: 3}
  m_Name: Narrative_NoiseIntro_Stonefall
  m_EditorClassIdentifier: Assembly-CSharp::_Scripts.Tutorial.TutorialNarrativeAsset
  beats:
  - speaker: 2
    text: ...still with me? That registered on my end. The impact sound carried.
      You need to bring your noise level down. Right now.
    autoAdvanceDelay: 4.5
    voiceClip: {fileID: 0}
    keepHologramActive: 1
  - speaker: 1
    text: There's something here. I can feel it.
    autoAdvanceDelay: 1.5
    voiceClip: {fileID: 8300000, guid: e11a3f731847f0448845ec6c60b679ba, type: 3}
    keepHologramActive: 1
  - speaker: 2
    text: 'Yes. That would be a Lurker. Fascinating thing. '
    autoAdvanceDelay: 1.5
    voiceClip: {fileID: 8300000, guid: e11a3f731847f0448845ec6c60b679ba, type: 3}
    keepHologramActive: 1
  - speaker: 2
    text: Stop moving like you have somewhere to be. Slow down. Let the meter settle.
      You'll know when it's working.
    autoAdvanceDelay: 4
    voiceClip: {fileID: 8300000, guid: e11a3f731847f0448845ec6c60b679ba, type: 3}
    keepHologramActive: 1
